#!/bin/sh
### BEGIN INIT INFO
# Provides: unow-signal-diag
# Required-Start: $network
# Required-Stop:
# Default-Start: 2 3 4 5
# Default-Stop: 0 1 6
# Short-Description: UNOW Wi-Fi signal diagnostic daemon
### END INIT INFO

set -eu

SCRIPT="${UNOW_SIGNAL_DIAG_SCRIPT:-/usr/bin/scripts/unow-signal-diag.sh}"
PIDFILE="${UNOW_SIGNAL_DIAG_PIDFILE:-/var/run/unow-signal-diag.pid}"
LOG_DIR="${UNOW_SIGNAL_DIAG_LOG_DIR:-/var/log/unow}"

log() {
    echo "[S99unow-signal-diag] $*"
}

start() {
    if [ ! -x "$SCRIPT" ]; then
        log "ERROR: script not found or not executable: $SCRIPT"
        return 1
    fi

    mkdir -p "$LOG_DIR"

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
        log "already running (pid $(cat "$PIDFILE" 2>/dev/null))"
        return 0
    fi

    log "starting diagnostic daemon with script=$SCRIPT log_dir=$LOG_DIR"

    if command -v start-stop-daemon >/dev/null 2>&1; then
        start-stop-daemon -S -b -m -p "$PIDFILE" -x "$SCRIPT" -- \
            --iface "${UNOW_SIGNAL_DIAG_IFACE:-wlan0}" \
            --bssid "${UNOW_SIGNAL_DIAG_BSSID:-55:4E:4F:57:00:01}" \
            --log-dir "$LOG_DIR"
    else
        "$SCRIPT" \
            --iface "${UNOW_SIGNAL_DIAG_IFACE:-wlan0}" \
            --bssid "${UNOW_SIGNAL_DIAG_BSSID:-55:4E:4F:57:00:01}" \
            --log-dir "$LOG_DIR" >"$LOG_DIR/S99unow-signal-diag.stdout" 2>"$LOG_DIR/S99unow-signal-diag.stderr" &
        echo $! > "$PIDFILE"
    fi
}

stop() {
    if [ -f "$PIDFILE" ]; then
        pid="$(cat "$PIDFILE" 2>/dev/null || true)"
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            log "stopping pid=$pid"
            kill "$pid" 2>/dev/null || true
            sleep 1
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$PIDFILE"
    else
        log "not running"
    fi
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
        log "running (pid $(cat "$PIDFILE" 2>/dev/null))"
        return 0
    fi
    log "stopped"
    return 3
}

case "${1:-start}" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop || true
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}" >&2
        exit 1
        ;;
esac
