#!/bin/sh
#
# buildspot-recv: Start buildspot receiver service
#

DAEMON="/oem/usr/bin/buildspot-recv.sh"
PIDFILE="/var/run/buildspot-recv.pid"
LOGFILE="/var/log/buildspot-recv.log"

start() {
    printf "Starting buildspot-recv: "
    if [ ! -x "$DAEMON" ]; then
        echo "FAIL (daemon not found)"
        exit 1
    fi
    # Use /bin/sh instead of /bin/bash for better compatibility
    start-stop-daemon -S -b -p "$PIDFILE" -m --exec /bin/sh -- "$DAEMON"
    [ $? = 0 ] && echo "OK" || echo "FAIL"
}

stop() {
    printf "Stopping buildspot-recv: "
    start-stop-daemon -K -p "$PIDFILE"
    [ $? = 0 ] && echo "OK" || echo "FAIL"
    rm -f "$PIDFILE"
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if [ -d "/proc/$PID" ]; then
            echo "buildspot-recv is running (pid $PID)"
            return 0
        fi
    fi
    echo "buildspot-recv is NOT running"
    return 3
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
esac

exit $?
